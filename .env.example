# NAVER Cloud Platform Maps 인증 정보다.
# 이 파일을 .env로 복사한 뒤 본인 값을 입력한다.
# NAVER_MAPS_API_KEY_ID는 Dynamic Map SDK 로딩을 위해 브라우저로 전달된다.
NAVER_MAPS_API_KEY_ID=
# NAVER_MAPS_API_KEY는 Geocoding, Reverse Geocoding, 향후 Directions 5 프록시 호출을 위해 로컬 서버에만 둔다.
NAVER_MAPS_API_KEY=

# 선택적 로컬 개발 서버 설정이다.
QUESTBOOK_HOST=0.0.0.0
QUESTBOOK_PORT=8000
QUESTBOOK_PUBLIC_URL=http://100.87.116.106:8000

# baseline 분리 서버 설정이다.
QUESTBOOK_WEB_HOST=0.0.0.0
QUESTBOOK_WEB_PORT=8000
QUESTBOOK_APP_API_HOST=127.0.0.1
QUESTBOOK_APP_API_PORT=8100
QUESTBOOK_APP_API_BASE_URL=http://127.0.0.1:8100
QUESTBOOK_CACHE_TTL_SECONDS=1800
QUESTBOOK_JWT_SECRET=questbook-local-dev-secret-change-before-deploy

# PostgreSQL/Redis 로컬 baseline 설정이다.
# infra/local/postgres-redis.compose.yaml의 기본값과 맞춘다.
QUESTBOOK_DATABASE_URL=postgresql://questbook:questbook_local_password@127.0.0.1:5432/questbook
QUESTBOOK_REDIS_URL=redis://127.0.0.1:6379/0
QUESTBOOK_POSTGRES_DB=questbook
QUESTBOOK_POSTGRES_USER=questbook
QUESTBOOK_POSTGRES_PASSWORD=questbook_local_password
QUESTBOOK_POSTGRES_PORT=5432
QUESTBOOK_REDIS_PORT=6379

# NCP Object Storage 사진 증빙 저장 설정이다.
# 버킷은 비공개로 생성하고, 브라우저에는 API Key를 노출하지 않는다.
NCP_OBJECT_STORAGE_ENDPOINT_URL=https://kr.object.ncloudstorage.com
NCP_OBJECT_STORAGE_REGION_NAME=kr-standard
NCP_OBJECT_STORAGE_BUCKET_NAME=
NCP_OBJECT_STORAGE_ACCESS_KEY=
NCP_OBJECT_STORAGE_SECRET_KEY=
NCP_OBJECT_STORAGE_PRESIGNED_URL_TTL_SECONDS=600
NCP_OBJECT_STORAGE_MAX_UPLOAD_BYTES=10485760
NCP_OBJECT_STORAGE_ADDRESSING_STYLE=path

# 한국관광공사 TourAPI 서비스 키다. 비어 있으면 대전 fallback 데이터로 baseline 흐름을 실행한다.
# 공공데이터포털에서 발급한 Decoding 키를 권장하며, Encoding 키를 넣어도 앱 API가 한 번 디코딩한 뒤 호출한다.
TOURAPI_SERVICE_KEY=

# Gemini는 baseline에서 필수 호출하지 않고 향후 퀘스트 문구 다양화 단계에서 사용한다.
GEMINI_API_KEY=

# OAuth 콜백 redirect_uri의 기준 origin이다. 로컬 OAuth 로그인은 브라우저도 http://localhost:8000 으로 접속한다. 운영은 https://www.travel-qbook.co.kr
QUESTBOOK_PUBLIC_BASE_URL=http://localhost:8000
# 네이버 로그인 자격증명이다(지도 키 NAVER_MAPS_*와 별개).
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
# 구글 로그인 자격증명이다.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
