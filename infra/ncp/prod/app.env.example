# app-api 프로덕션 env. 시크릿 실값은 커밋하지 않는다.
QUESTBOOK_APP_API_HOST=0.0.0.0
QUESTBOOK_APP_API_PORT=8100
QUESTBOOK_PUBLIC_BASE_URL=https://www.travel-qbook.co.kr
QUESTBOOK_DATABASE_URL=postgresql://<db_user>:<db_password>@<cloud-db-private-domain>:5432/<db_name>
QUESTBOOK_REDIS_URL=redis://<cloud-db-cache-private-domain>:6379/0
# 필수: 32자 이상 강한 값. 비워두거나 약한 값이면 앱이 기동을 거부한다.
QUESTBOOK_JWT_SECRET=
NAVER_MAPS_API_KEY_ID=
NAVER_MAPS_API_KEY=
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
TOURAPI_SERVICE_KEY=
NCP_OBJECT_STORAGE_ENDPOINT_URL=https://kr.object.ncloudstorage.com
NCP_OBJECT_STORAGE_REGION_NAME=kr-standard
NCP_OBJECT_STORAGE_BUCKET_NAME=
NCP_OBJECT_STORAGE_ACCESS_KEY=
NCP_OBJECT_STORAGE_SECRET_KEY=
NCP_OBJECT_STORAGE_PRESIGNED_URL_TTL_SECONDS=600
NCP_OBJECT_STORAGE_MAX_UPLOAD_BYTES=10485760
NCP_OBJECT_STORAGE_ADDRESSING_STYLE=path
NCP_CLOVA_OCR_INVOKE_URL=
NCP_CLOVA_OCR_SECRET_KEY=
NCP_CLOVA_OCR_LANGUAGE=ko
NCP_CLOVA_OCR_TIMEOUT_SECONDS=8
